<div>
  <p style="font-size:40px;padding:30px;"><%- page.title %></p>
</div>
<% var list=site.tags.data.sort((a,b)=>{
  return a.name<b.name?-1:1
}) %>
<% if(list&&list.length){ %>
<div class="card" style="padding: 10px;max-width:max(80%,350px);">
<% list.forEach((a)=>{ %>
  <a href="/<%= a.path %>" style="margin:10px;padding:5px;"><%= a.name %></a>
<% }) %>
<% } %>
</div>